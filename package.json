{
  "name": "student-db",
  "version": "1.0.0",
  "description": "db for students",
  "keywords": [],
  "homepage": "https://github.com/codye1/student-db#readme",
  "bugs": {
    "url": "https://github.com/codye1/student-db/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codye1/student-db.git"
  },
  "license": "ISC",
  "author": "Mykhailo Lyzanets",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node app.js",
    "predev": "npm run check",
    "dev": "node --watch app.js",
    "external": "json-server db.json --port 3001",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run lint && npm run format:check",
    "test": "echo \"Error: no test specified\" && exit 1",
    "seed": "node src/scripts/seed.js",
    "seed:force": "node src/scripts/seed.js --force",
    "migrate": "npx drizzle-kit migrate",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.4.0",
    "json-server": "^1.0.0-beta.3",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^5.0.3",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.5.2",
    "@fastify/swagger-ui": "^5.2.3",
    "@fastify/websocket": "^11.2.0",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.7.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.0.0",
    "mysql2": "^3.12.0"
  },
  "imports": {
    "#controllers/*": "./controllers/*.js",
    "#services/*": "./services/*.js",
    "#helpers/*": "./helpers/*.js",
    "#validators/*": "./validators/*.js"
  }
}
